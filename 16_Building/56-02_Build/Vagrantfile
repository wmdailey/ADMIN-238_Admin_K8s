Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  # --- Hostmanager Configuration ---
  # Note: Ensure you have installed the plugin: vagrant plugin install vagrant-hostmanager
  config.hostmanager.enabled = true
  config.hostmanager.manage_host = true      # Updates your Mac's /etc/hosts
  config.hostmanager.manage_guest = true     # Updates each VM's /etc/hosts
  config.hostmanager.ignore_private_ip = false
  config.hostmanager.include_offline = false

  # 1. Load Balancer
  config.vm.define "lb01" do |node|
    node.vm.hostname = "lb01"
    node.vm.network "private_network", ip: "192.168.50.10"
    node.vm.provider "parallels" do |v|
      v.memory = 1024
      v.cpus = 1
    end
  end

  # 2. Master Nodes
  (1..3).each do |i|
    config.vm.define "master0#{i}" do |node|
      node.vm.hostname = "master0#{i}"
      node.vm.network "private_network", ip: "192.168.50.1#{i}"
      node.vm.provider "parallels" do |v|
        v.memory = 2048
        v.cpus = 2
        v.linked_clone = true
      end
    end
  end

  # 3. Worker Nodes
  (1..4).each do |i|
    config.vm.define "worker0#{i}" do |node|
      node.vm.hostname = "worker0#{i}"
      node.vm.network "private_network", ip: "192.168.50.2#{i}"
      node.vm.provider "parallels" do |v|
        v.memory = 2048
        v.cpus = 2
        v.linked_clone = true
      end
    end
  end
end
